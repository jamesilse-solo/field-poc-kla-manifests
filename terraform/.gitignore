# Terraform state files - contain sensitive data
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform directories
.terraform/
.terraform.lock.hcl

# Variable files that might contain secrets
*.tfvars
!terraform.tfvars.example

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan files
*.tfplan

# kubeconfig files if generated locally
kubeconfig*
*.kubeconfig
